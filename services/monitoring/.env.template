# =============================================================================
# Monitoring API — environment template
#   cp .env.template .env   (then fill in for your environment)
# Safe local defaults target the published 127.0.0.1 dev-host ports from
# infra/monitoring/.env. In staging/prod these become internal service names on
# the `monitoring` network and secrets come from SSM / Secrets Manager.
# =============================================================================

NODE_ENV=development

# API listener. Loopback-only in dev.
MONITORING_API_PORT=3009
MONITORING_API_BIND=127.0.0.1

# Optional shared-secret gate. Empty = open (loopback dev only). In staging/prod
# set a strong token; the admin panel injects it server-side.
MONITORING_API_TOKEN=

# Comma-separated allowed browser origins (the admin panel). Empty = none.
MONITORING_CORS_ORIGINS=

# --- Upstream base URLs (no trailing slash) ---------------------------------
# Dev-host defaults (published 127.0.0.1 ports). In prod use internal names:
#   http://prometheus:9090  http://alertmanager:9093  http://loki:3100 ...
PROMETHEUS_URL=http://127.0.0.1:9090
ALERTMANAGER_URL=http://127.0.0.1:9093
LOKI_URL=http://127.0.0.1:3100
GRAFANA_URL=http://127.0.0.1:3001
UPTIME_KUMA_URL=http://127.0.0.1:3002
BULL_BOARD_URL=http://127.0.0.1:3003

# --- Upstream credentials (server-side only) --------------------------------
GRAFANA_SA_TOKEN=
UPTIME_KUMA_API_KEY=
UPTIME_KUMA_STATUS_SLUG=saludlink
BULL_BOARD_USER=admin
BULL_BOARD_PASSWORD=change_me_bullboard

# --- Gated SaaS integrations (leave blank pre-launch) -----------------------
GITHUB_TOKEN=
GITHUB_REPO=
POSTHOG_PROJECT_API_KEY=
POSTHOG_PROJECT_ID=
POSTHOG_HOST=https://us.posthog.com

# --- Tuning -----------------------------------------------------------------
UPSTREAM_TIMEOUT_MS=5000
CACHE_TTL_SECONDS=10
