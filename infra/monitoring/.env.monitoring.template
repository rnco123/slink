# =============================================================================
# Saludlink — Monitoring stack environment
# -----------------------------------------------------------------------------
# Copy to `.env` inside infra/monitoring/ and fill in.
#   cp .env.monitoring.template .env
# Values below are SAFE LOCAL DEFAULTS for dev. NEVER commit real secrets.
# In staging/production these come from AWS Secrets Manager / the CI secret store.
#
# Design goals honoured by these vars:
#   * Self-hosted where possible.
#   * Nothing binds to 0.0.0.0 in dev — every published port is 127.0.0.1 only.
#   * Exporters (node/pg/redis/cadvisor/blackbox) are NOT published at all; they
#     are reached by Prometheus over the internal `monitoring` network.
#   * Admin-only UIs (Grafana, Uptime Kuma, Bull Board) are the only web faces.
# =============================================================================

# --- Deployment target ------------------------------------------------------
# development | staging | production. Docs describe the per-env overrides.
MONITORING_ENV=development

# The bind address for every PUBLISHED port. Keep 127.0.0.1 on shared/dev hosts.
# In staging/production leave published ports OFF entirely and route through the
# admin subdomain / VPC (see README "Production exposure").
BIND_ADDR=127.0.0.1

# --- Data-source wiring (the app's Postgres + Redis) ------------------------
# The monitoring stack joins the app's docker network (APP_NETWORK) so the
# exporters can reach the database and cache by their compose service names.
# Change APP_NETWORK if your app compose project is not named "saludlink".
APP_NETWORK=saludlink_default

# Postgres exporter connection (points at the app DB container by service name).
# Use a READ-ONLY monitoring role in staging/production, never the app superuser.
PG_EXPORTER_DSN=postgresql://saludlink:saludlink_local@postgres:5432/medusa?sslmode=disable

# Redis exporter target.
REDIS_EXPORTER_ADDR=redis://redis:6379
# REDIS_EXPORTER_PASSWORD=

# Bull Board reads the same Redis (Medusa v2 event bus / workflow engine use
# BullMQ on this instance). Host/port as seen from inside the monitoring network.
BULL_REDIS_HOST=redis
BULL_REDIS_PORT=6379
# BULL_REDIS_PASSWORD=

# --- Grafana ----------------------------------------------------------------
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
# CHANGE THIS. In prod, inject from Secrets Manager.
GRAFANA_ADMIN_PASSWORD=change_me_grafana
# Public root URL Grafana believes it is served from (affects links / OAuth).
GRAFANA_ROOT_URL=http://localhost:3001
# Sign-up is disabled; admins are provisioned. Set to true only behind SSO.
GRAFANA_ALLOW_SIGNUP=false

# --- Prometheus -------------------------------------------------------------
PROMETHEUS_PORT=9090
# How long to keep TSDB samples on disk.
PROMETHEUS_RETENTION=15d

# --- Alertmanager -----------------------------------------------------------
ALERTMANAGER_PORT=9093
# Where alerts go. Leave blank in dev (alerts fire to the UI only).
ALERT_SLACK_WEBHOOK_URL=
ALERT_EMAIL_TO=
ALERT_SMTP_SMARTHOST=
ALERT_SMTP_FROM=alertmanager@saludlinkusa.com

# --- Loki / Promtail (logging) ----------------------------------------------
LOKI_PORT=3100
# Log retention. HIPAA note: logs must never contain PHI, secrets, or request
# bodies — Promtail is configured to drop known-sensitive fields.
LOKI_RETENTION_HOURS=336h

# --- Uptime Kuma (synthetic website monitoring) -----------------------------
UPTIME_KUMA_PORT=3002

# --- Bull Board (BullMQ queue dashboard) ------------------------------------
BULL_BOARD_PORT=3003
# Basic-auth gate for the Bull Board UI (it has no built-in auth).
BULL_BOARD_USER=admin
BULL_BOARD_PASSWORD=change_me_bullboard

# --- cAdvisor (container metrics) -------------------------------------------
# Not published by default; set a port only if you must reach the UI directly.
CADVISOR_PORT=8081

# --- Blackbox exporter (HTTP/TCP/ICMP probes) -------------------------------
# Targets probed for uptime/latency. Comma-separated absolute URLs.
BLACKBOX_TARGETS=http://host.docker.internal:8000,http://host.docker.internal:9000/health
