{
  "//": "Lighthouse CI budgets — Saludlink. Runs on storefront PRs (lighthouse.yml). Wall is OFF in CI (COMING_SOON unset) so real pages are scored. Perf/a11y/best-practices are WARN until a real CI run calibrates them (the commerce tree is heavy); SEO/LCP/CLS are hard ERROR gates. Flip performance to error@0.95 once a run confirms the app clears it.",
  "ci": {
    "collect": {
      "startServerCommand": "pnpm --filter storefront start -p 8000",
      "startServerReadyPattern": "ready|started server on",
      "url": [
        "http://localhost:8000/en",
        "http://localhost:8000/en/telemedicine",
        "http://localhost:8000/en/about"
      ],
      "numberOfRuns": 3,
      "settings": {
        "preset": "desktop"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.95 }],
        "categories:seo": ["error", { "minScore": 0.95 }],
        "categories:accessibility": ["warn", { "minScore": 0.95 }],
        "categories:best-practices": ["warn", { "minScore": 0.95 }],
        "largest-contentful-paint": ["error", { "maxNumericValue": 2500 }],
        "cumulative-layout-shift": ["error", { "maxNumericValue": 0.1 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
