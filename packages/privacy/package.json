{
  "name": "@saludlink/privacy",
  "version": "0.1.0",
  "private": true,
  "description": "Saludlink PHI Boundary Firewall — keeps Protected Health Information out of the commerce website (Medusa, Cognito, Postgres, Stripe, PostHog, logs).",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./middleware": "./src/middleware.ts",
    "./analytics": "./src/analytics.ts",
    "./logger": "./src/safe-logger.ts",
    "./schemas": "./src/schemas.ts",
    "./zod": "./src/zod-helpers.ts"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.12.11",
    "typescript": "^5.6.2",
    "vitest": "^3.2.6"
  }
}
