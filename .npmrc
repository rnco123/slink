auto-install-peers=true
strict-peer-dependencies=false

# Medusa v2 admin (Vite) needs these resolvable from a hoisted node_modules. The storefront
# keeps its own React-19 copies locally, so hoisting these for the admin doesn't collide.
public-hoist-pattern[]=@medusajs/*
public-hoist-pattern[]=@tanstack/react-query
public-hoist-pattern[]=react-i18next
public-hoist-pattern[]=react-router-dom
