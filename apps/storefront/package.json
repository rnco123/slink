    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:commerce": "cross-env E2E_INCLUDE_COMMERCE=1 playwright test",
    "test:e2e:report": "playwright show-report e2e/.artifacts/report"
  },
  "dependencies": {
