{
  "name": "@saludlink/storefront",
  "version": "0.1.0",
  "private": true,
  "description": "Saludlink public storefront — saludlinkusa.com (Next.js 15)",
  "scripts": {
    "dev": "next dev --turbopack -p 8000",
    "build": "next build",
    "start": "next start -p 8000",
    "lint": "next lint",
    "analyze": "ANALYZE=true next build",
    "test:e2e:install": "playwright install chromium",
