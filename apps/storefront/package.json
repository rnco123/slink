    "@medusajs/ui": "latest",
    "@radix-ui/react-accordion": "^1.2.1",
    "@saludlink/privacy": "workspace:*",
    "@saludlink/ui": "workspace:*",
    "@stripe/react-stripe-js": "^5.3.0",
    "@stripe/stripe-js": "^8.2.0",
    "lodash": "^4.17.21",
    "next": "15.3.9",
    "pg": "^8.11.3",
    "posthog-js": "^1.406.2",
    "qs": "^6.12.1",
    "react": "19.0.5",
    "react-country-flag": "^3.1.0",
    "react-dom": "19.0.5",
    "server-only": "^0.0.1",
