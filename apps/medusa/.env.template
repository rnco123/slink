# =============================================================================
# Saludlink — Medusa v2 backend environment
# -----------------------------------------------------------------------------
# Copy to `.env` and fill in. Values below are SAFE LOCAL DEFAULTS for dev.
# NEVER commit real secrets. In production these come from AWS Secrets Manager.
# =============================================================================

# --- Core -------------------------------------------------------------------
# Node environment: development | production | test
NODE_ENV=development

# Postgres connection string. Local default matches the dev docker-compose.
# Production: RDS Postgres 16 endpoint (BAA-eligible).
DATABASE_URL=postgres://saludlink:saludlink_local@localhost:5432/medusa

# Redis. When set, Medusa uses Redis for the event bus, workflow engine, and
# cache. Leave EMPTY for a first boot to fall back to in-memory (dev only —
# in-memory has no durable workflows / cross-process events).
# Production: ElastiCache Redis endpoint.
REDIS_URL=redis://localhost:6379

# --- Auth secrets -----------------------------------------------------------
# Override BOTH in production with long random values (Secrets Manager).
JWT_SECRET=supersecret
COOKIE_SECRET=supersecret

# --- CORS -------------------------------------------------------------------
# Comma-separated allowed origins.
# STORE_CORS  = the Next.js storefront (default :8000)
# ADMIN_CORS  = the Medusa admin (default :9000) + vite dev (:5173)
# AUTH_CORS   = origins allowed to hit /auth (storefront + admin)
STORE_CORS=http://localhost:8000
ADMIN_CORS=http://localhost:9000,http://localhost:5173
AUTH_CORS=http://localhost:8000,http://localhost:9000,http://localhost:5173

# --- Admin dashboard --------------------------------------------------------
# Public URL the backend/admin is reached at.
MEDUSA_BACKEND_URL=http://localhost:9000
# Set to true on worker/API-only deployments to not build/serve the admin.
MEDUSA_ADMIN_DISABLE=false
# Redirect target after admin login flows (Medusa admin onward URL).
MEDUSA_ADMIN_ONWARD=

# --- Stripe payments (@medusajs/payment-stripe) -----------------------------
# Provider is only registered when STRIPE_API_KEY is present.
# Use test-mode keys (sk_test_...) in dev. See STRIPE.md for webhook setup.
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# --- S3 file storage (@medusajs/file-s3) ------------------------------------
# Enabled only when S3_BUCKET + S3_REGION + S3_FILE_URL are all set,
# otherwise the local file provider (./static) is used.
# Production: S3 bucket fronted by CloudFront.
S3_FILE_URL=
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Optional: custom endpoint for S3-compatible object stores (MinIO, etc.).
S3_ENDPOINT=

# --- AWS SES email (@medusajs/notification-ses) -----------------------------
# Enabled only when SES_FROM + SES_REGION are set, else local (logs) provider.
# Order emails name health products → SES is BAA-eligible (sign AWS BAA first).
SES_FROM=no-reply@saludlinkusa.com
SES_REGION=
SES_ACCESS_KEY_ID=
SES_SECRET_ACCESS_KEY=

# Generic AWS creds — SES falls back to these if the SES_* specific vars are
# unset. Handy when running on an instance/role that already provides them.
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
